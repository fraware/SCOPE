{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "SCOPE Domain Overlay",
  "type": "object",
  "required": ["overlay_id", "version"],
  "properties": {
    "overlay_id": { "type": "string", "minLength": 1 },
    "version": { "type": "string", "minLength": 1 },
    "description": { "type": "string" },
    "matrix_overrides": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "required_roles": {
            "type": "array",
            "items": { "type": "string" }
          },
          "require_all": { "type": "boolean" },
          "require_any": { "type": "boolean" }
        }
      }
    },
    "notes": { "type": "string" },
    "mandatory_session_roles": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "additionalProperties": true
}
